# Server
PORT=
NODE_ENV=

# Public base URL used in email links (no trailing slash)
APP_BASE_URL=

# Supabase — get these from your project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Gmail SMTP — use an App Password, not your regular Gmail password
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Auth strategy (keep as supabase)
JWT_AUTH_STRATEGY=
